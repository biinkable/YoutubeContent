# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Get a key at https://console.cloud.google.com/ → enable "YouTube Data API v3" → Credentials → Create API key.
YOUTUBE_API_KEY=
# kie.ai — the DEFAULT image provider (cheaper GPT-image-2 gateway). Get a key at https://kie.ai/api-key
KIE_API_KEY=
# OpenAI — optional fallback image provider (paid). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
